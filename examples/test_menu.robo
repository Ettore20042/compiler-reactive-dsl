task sum(a: real, b: real) -> real {
    return a + b;
}

task subtract(a: real, b: real) -> real {
    return a - b;
}

var choice: int = 0;
var num1: real = 0.0;
var num2: real = 0.0;
var res: real = 0.0;

while (choice != 3) {
    log("=== MENU ARITMETICO ===");
    log("1. Addizione");
    log("2. Sottrazione");
    log("3. Esci");
    log("Inserisci la scelta (1-3):");
    set choice = read_int();

    when (choice == 1) {
        log("Inserisci il primo numero:");
        set num1 = read_real();
        log("Inserisci il secondo numero:");
        set num2 = read_real();
        set res = sum(num1, num2);
        log("Risultato:");
        log(res);
    }

    when (choice == 2) {
        log("Inserisci il primo numero:");
        set num1 = read_real();
        log("Inserisci il secondo numero:");
        set num2 = read_real();
        set res = subtract(num1, num2);
        log("Risultato:");
        log(res);
    }

    when (choice == 3) {
        log("Uscita dal programma.");
    }
}
